---
import RootLayout from "@layouts/RootLayout.astro"

import { Image } from 'astro:assets'

import me from '@assets/img/me/2022.jpg'
---

<RootLayout>
  <header class="flex flex-col-reverse md:(flex-row justify-between) md:h-2xl items-center">
    <div class="max-w-2xl flex flex-col justify-center">
      <p class="text-lg md:text-xl font-medium">Hi, my name is</p>
      <h1 class="text-6xl md:text-8xl font-bold mb-6 relative text-sky tracking-tighter">
        Justin Forlenza
        <div
          class="w-3/4 h-full absolute blur-[60px] opacity-25 bg-gradient-to-br from-indigo-4 to-purple-4 top-2 left-0 -z-1 rounded-xl"
        >
        </div>
      </h1>
      <p class="md:text-lg font-medium">
        I am a Full Stack Developer & I.T. Specialist living in New York City,
        with a passion for developing intuitive solutions for any problem.
      </p>
    </div>
    <div class="text-center relative">
      <Image
        class="rounded-xl max-w-64 md:max-w-none"
        src={me}
        alt="Justin Forlenza"
        width={400}
        height={400}
      />

      <a
        class="bg-sky-5 rounded-lg px-4 py-3 font-bold relative -top-5 hover:bg-sky-6 ring-sky-5/70 active:ring focus:ring transition-all"
        href="/contact"
      >
        Get in touch!
      </a
      >
    </div>
  </header>
  <section class="mt-12">
    <h2>About Me</h2>
  </section>
</RootLayout>
