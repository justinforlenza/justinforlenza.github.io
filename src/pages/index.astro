---
import { getCollection } from 'astro:content'
import Experience from '../components/homepage/experience.astro'
import Main from '../layouts/main.astro'

const posts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true
})
---

<Main>
  <div slot="header">
    <h1>Justin Forlenza <span class="blink-cursor"></span></h1>
    <p>full-stack developer &middot; educator</p>
    <dl>
      <dt>role</dt>
      <dd>
        full-stack instructor @&nbsp;
        <a
          target="_blank"
          href="https://brooklynsteamcenter.org"
          rel="noopener noreferrer"
        >
          Brooklyn STEAM Center
        </a>
      </dd>
      <dt>loc</dt>
      <dd>new york city</dd>
      <dt>email</dt>
      <dd>
        <a href="mailto:justin@justinforlenza.dev">
          justin@justinforlenza.dev
        </a>
      </dd>
    </dl>
  </div>

  <section id="about">
    <h2>about</h2>
    <p>
      building intuitive solutions to messy problems. i teach full-stack
      development by day and spend the rest of my time shipping apps and
      tinkering with technology
    </p>
  </section>

  <section id="projects">
    <h2>projects</h2>
    <ul>
      <li>
        <strong>pyrepl</strong>
        &nbsp;- browser-based python REPL
      </li>
      <li>
        <strong>keylight-control</strong>
        &nbsp;- linux app for Elgato Key Lights
      </li>
      <li>
        <strong>home-assistant-tray</strong>
        &nbsp;- Home Assistant in your system tray
      </li>
    </ul>
    <a href="/projects">view more...</a>
  </section>

  <Experience />

  {posts.length > 0 && <section id="ramblings" class="wide">
    <h2>writing</h2>
    <dl>
      {posts.slice(0, 5).map(p => <>
        <dt>{p.data.published.toISOString().split('T')[0]}</dt> <dd><a href={`/ramblings/${p.id}`}>{p.data.name}</a></dd>
      </>)}
    </dl>
    {posts.length > 5 && <a href="/ramblings">view more...</a>}
  </section>}
</Main>

<style>
dd a {
  color: unset;
}
</style>
