---
import RootLayout from "@layouts/RootLayout.astro";
---

<RootLayout>
  <header class="flex flex-row justify-between h-2xl items-center">
    <div class="max-w-2xl flex flex-col justify-center">
      <p class="text-xl">Hi, my name is</p>
      <h1 class="text-8xl font-bold mb-6 relative text-sky">
        Justin Forlenza
        <div
          class="w-3/4 h-full absolute blur-[60px] opacity-25 bg-gradient-to-br from-indigo-4 to-purple-4 top-2 left-0 -z-1 rounded-xl"
        >
        </div>
      </h1>
      <p class="text-lg">
        I am a Full Stack Developer & I.T. Specialist living in New York City,
        with a passion for developing intuitive solutions for any problem.
      </p>
    </div>
    <div class="text-center relative">
      <img
        class="rounded-xl"
        src="https://placehold.co/400"
        alt="picture of justin forlenza"
      />

      <a
        class="bg-sky-5 rounded-lg px-4 py-3 font-bold relative -top-5 hover:bg-sky-6 ring-sky-5/70 active:ring focus:ring transition-all"
        href="/contact"
      >
        Get in touch!
      </a
      >
    </div>
  </header>
  <section class="mt-12">
    <h2>About Me</h2>
  </section>
</RootLayout>
