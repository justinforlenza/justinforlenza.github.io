---
import { getCollection } from 'astro:content'
import Base from './base.astro'

const socials = await getCollection('socials')

const logo = `
               ##
             ####
           #####
          #####
         ####
         ###  #
       # ### ##
      ## ######
      ## ######
     ### #####
     ### ###
     ### ###
     ### ###
     ### ##
     ### ##
     ### #
     ###
    ###
  #####
 #####
####
##`

const posts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true
})

interface Props {
  title?: string
}

const { title } = Astro.props
---

<Base title={title}>
  <nav>
    <a href="/">about</a>
    <a href="/projects">projects</a>
    {posts.length > 0 && <a href="/ramblings">ramblings</a>}
    <a href="/contact">contact</a>
  </nav>
  <slot name="header-all">
    <header>
      <pre aria-hidden="true">{logo}</pre>
      <slot name="header" />
    </header>
  </slot>
  <slot name="main">
    <main>
      <slot />
    </main>
  </slot>

  <footer>
    {socials.map((social) => (
        <a href={social.data.url} target="_blank" rel="noopener noreferrer">
          {social.data.name}
        </a>
      ))}
  </footer>
</Base>

<style>
pre {
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  overflow: visible;
  line-height: 1;
  font-size: 1ch;
  color: var(--title);
  white-space: pre;
  user-select: none;
}

@media (max-width: 36rem) {
  header {
    flex-direction: column;
    align-items: stretch;

    > pre {
      align-self: center;
    }
  }
}
</style>
