---
import '../styles/_index.css'

import { getCollection } from 'astro:content'

const socials = await getCollection('socials')

const logo = `
               ##
             ####
           #####
          #####
         ####
         ###  #
       # ### ##
      ## ######
      ## ######
     ### #####
     ### ###
     ### ###
     ### ###
     ### ##
     ### ##
     ### #
     ###
    ###
  #####
 #####
####
##`
---

<html lang="en" data-theme="one-dark-two">
  <head>
    <meta charset="utf-8">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" href="/favicon.ico">
    <meta name="viewport" content="width=device-width">
    <meta name="generator" content={Astro.generator}>
    <title>Justin Forlenza</title>
  </head>
  <body>
    <header>
      <slot name="header">
        <pre aria-hidden="true">{logo}</pre>
        <div>
          <h1>Justin Forlenza <span class="blink-cursor"></span></h1>
          <p>full-stack developer &middot; educator</p>
          <dl>
            <dt>role</dt>
            <dd>
              full-stack instructor @&nbsp;
              <a target="_blank" href="https://brooklynsteamcenter.org">
                Brooklyn STEAM Center
              </a>
            </dd>
            <dt>loc</dt>
            <dd>new york city</dd>
            <dt>email</dt>
            <dd>
              <a href="mailto:justin@justinforlenza.dev">
                justin@justinforlenza.dev
              </a>
            </dd>
          </dl>
        </div>
      </slot>
    </header>
    <main>
      <slot />
    </main>

    <footer>
      {socials.map((social) => (
        <a href={social.data.url} target="_blank" rel="noopener noreferrer">
          {social.data.name}
        </a>
      ))}
    </footer>
  </body>
</html>

<style>
pre {
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  overflow: visible;
  line-height: 1;
  font-size: clamp(0.45rem, 0.38rem + 0.5vw, 0.62rem);
  color: var(--title);
  white-space: pre;
  user-select: none;
}

@media (max-width: 36rem) {
  header {
    flex-direction: column;
    align-items: stretch;

    > pre {
      align-self: center;
    }
  }
}
</style>
