---
import { getCollection } from 'astro:content'
import Base from './base.astro'

const socials = await getCollection('socials')

const logo = `
               ##
             ####
           #####
          #####
         ####
         ###  #
       # ### ##
      ## ######
      ## ######
     ### #####
     ### ###
     ### ###
     ### ###
     ### ##
     ### ##
     ### #
     ###
    ###
  #####
 #####
####
##`

interface Props {
  title?: string
}

const { title } = Astro.props
---

<Base title={title}>
  <nav>
    <a href="/">about</a>
    <a href="/projects">projects</a>
    <!-- <a href="#experience">experience</a> -->
    <!-- <a href="/writing">writing</a> -->
    <a href="/contact">contact</a>
  </nav>
  <header>
    <slot name="header">
      <pre aria-hidden="true">{logo}</pre>
      <div>
        <h1>Justin Forlenza <span class="blink-cursor"></span></h1>
        <p>full-stack developer &middot; educator</p>
        <dl>
          <dt>role</dt>
          <dd>
            full-stack instructor @&nbsp;
            <a target="_blank" href="https://brooklynsteamcenter.org">
              Brooklyn STEAM Center
            </a>
          </dd>
          <dt>loc</dt>
          <dd>new york city</dd>
          <dt>email</dt>
          <dd>
            <a href="mailto:justin@justinforlenza.dev">
              justin@justinforlenza.dev
            </a>
          </dd>
        </dl>
      </div>
    </slot>
  </header>
  <main>
    <slot />
  </main>

  <footer>
    {socials.map((social) => (
        <a href={social.data.url} target="_blank" rel="noopener noreferrer">
          {social.data.name}
        </a>
      ))}
  </footer>
</Base>

<style>
pre {
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 0;
  overflow: visible;
  line-height: 1;
  font-size: 1ch;
  color: var(--title);
  white-space: pre;
  user-select: none;
}

@media (max-width: 36rem) {
  header {
    flex-direction: column;
    align-items: stretch;

    > pre {
      align-self: center;
    }
  }
}
</style>
